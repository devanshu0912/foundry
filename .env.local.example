# Copy this file to .env.local and fill in your Supabase credentials
# Get these from: https://supabase.com → Your Project → Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Get this from: https://console.anthropic.com -> API Keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Supabase service role key — NEVER expose this to the browser
# Get from: Supabase → Settings → API → service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
